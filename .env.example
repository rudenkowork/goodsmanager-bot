BOT_TOKEN=1234567890:replace_with_botfather_token
MAIN_ADMIN_TELEGRAM_USERNAME=timarudy

# Production persistence. Use your Neon connection string with sslmode=require.
# Do not commit the real value.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Default local mode. Use webhook on Render Free web services.
BOT_MODE=polling

# Render webhook mode:
# BOT_MODE=webhook
# WEBHOOK_BASE_URL=https://your-service.onrender.com
# WEBHOOK_SECRET=replace_with_a_long_random_value_using_letters_numbers_underscores_or_dashes

# Optional fallback for local JSON storage when DATABASE_URL is not set.
# If omitted, the bot writes to ./data/store.json locally.
# STORE_PATH=/data/store.json

# Emergency override only. Production hosts normally refuse JSON fallback.
# ALLOW_JSON_STORE_IN_PRODUCTION=true
